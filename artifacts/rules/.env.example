# API Server URL (for API requests from frontend)
# For local development:
API_URL=http://localhost:3000

# For production (Cloudflare Pages):
# API_URL=https://your-api-server-domain.com

# Base path for Cloudflare Pages (if deployed to Pages)
# BASE_PATH=/

# Discord OAuth callback (if using Discord auth from frontend directly)
# DISCORD_REDIRECT_URI=https://your-domain.com/api/auth/discord/callback
